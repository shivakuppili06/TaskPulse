{
  "info": {
    "_postman_id": "todoapp-v2-collection",
    "name": "todoapp API",
    "description": "All endpoints for the todoapp Express backend. Base URL: http://localhost:5000",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "http://localhost:5000/api/health",
        "description": "Check if the server is running"
      }
    },
    {
      "name": "Get All Todos",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:5000/api/todos",
          "host": ["http://localhost:5000/api/todos"],
          "query": [
            { "key": "status", "value": "active", "disabled": true },
            { "key": "priority", "value": "high", "disabled": true },
            { "key": "search", "value": "buy", "disabled": true },
            { "key": "sortBy", "value": "dueDate", "disabled": true },
            { "key": "order", "value": "asc", "disabled": true },
            { "key": "category", "value": "Work", "disabled": true },
            { "key": "tag", "value": "urgent", "disabled": true },
            { "key": "page", "value": "1", "disabled": true },
            { "key": "limit", "value": "20", "disabled": true }
          ]
        },
        "description": "Fetch todos with optional filtering, sorting, and pagination"
      }
    },
    {
      "name": "Get Todo by ID",
      "request": {
        "method": "GET",
        "url": "http://localhost:5000/api/todos/:id",
        "description": "Fetch a single todo by its UUID"
      }
    },
    {
      "name": "Create Todo",
      "request": {
        "method": "POST",
        "url": "http://localhost:5000/api/todos",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Buy groceries\",\n  \"description\": \"Milk, eggs, bread\",\n  \"priority\": \"medium\",\n  \"dueDate\": \"2026-07-01\",\n  \"category\": \"Personal\",\n  \"tags\": [\"shopping\", \"home\"],\n  \"repeat\": \"weekly\",\n  \"timeEstimate\": 30,\n  \"pinned\": false\n}"
        },
        "description": "Create a new todo. repeat: daily | weekly | monthly | null"
      }
    },
    {
      "name": "Update Todo (full)",
      "request": {
        "method": "PUT",
        "url": "http://localhost:5000/api/todos/:id",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Buy groceries (updated)\",\n  \"priority\": \"high\",\n  \"completed\": false,\n  \"repeat\": \"monthly\"\n}"
        }
      }
    },
    {
      "name": "Patch Todo (partial)",
      "request": {
        "method": "PATCH",
        "url": "http://localhost:5000/api/todos/:id",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"completed\": true\n}"
        },
        "description": "Partial update. Completing a recurring task auto-creates next occurrence."
      }
    },
    {
      "name": "Delete Todo",
      "request": {
        "method": "DELETE",
        "url": "http://localhost:5000/api/todos/:id"
      }
    },
    {
      "name": "Bulk Delete Todos",
      "request": {
        "method": "DELETE",
        "url": "http://localhost:5000/api/todos",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"ids\": [\"uuid-1\", \"uuid-2\"]\n}"
        },
        "description": "Delete specific todos by ID array. Omit ids to clear all completed todos."
      }
    },
    {
      "name": "Clear Completed",
      "request": {
        "method": "DELETE",
        "url": "http://localhost:5000/api/todos",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "description": "Delete all completed todos"
      }
    },
    {
      "name": "Reorder Todos",
      "request": {
        "method": "POST",
        "url": "http://localhost:5000/api/todos/reorder",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"ids\": [\"uuid-3\", \"uuid-1\", \"uuid-2\"]\n}"
        },
        "description": "Persist custom drag-and-drop order. ids array defines the new sort order."
      }
    },
    {
      "name": "Export Todos (JSON)",
      "request": {
        "method": "GET",
        "url": "http://localhost:5000/api/todos/export?format=json",
        "description": "Download all todos as a JSON file"
      }
    },
    {
      "name": "Export Todos (CSV)",
      "request": {
        "method": "GET",
        "url": "http://localhost:5000/api/todos/export?format=csv",
        "description": "Download all todos as a CSV file"
      }
    },
    {
      "name": "Get Activity Log",
      "request": {
        "method": "GET",
        "url": "http://localhost:5000/api/todos/activity",
        "description": "Last 100 activity events (created, updated, completed, deleted)"
      }
    },
    {
      "name": "Get Stats",
      "request": {
        "method": "GET",
        "url": "http://localhost:5000/api/stats",
        "description": "Dashboard stats: total, active, completed, overdue, by-priority, by-category, weekly completion"
      }
    }
  ]
}
